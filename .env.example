# ===================================================================
# LOCAL EDS CONFIGURATION
# ===================================================================
# AEM_PAGES_URL point to the published AEM EDS instance where the content
# lives, can be the aem.live or aem.page URL
# You can use any branch as well so that you can test content in different
# branches.
# Examples:
#   AEM_PAGES_URL=https://main--test--blueacorninc.aem.page/ 
#   AEM_PAGES_URL=https://main--test2--blueacorninc.aem.live/
#   AEM_PAGES_URL=https://feature-branch--test3--blueacorninc.aem.page/
AEM_PAGES_URL=https://main--test--blueacorninc.aem.live/

# Needed to avoid certificate issues when running locally with HTTPS
# See Instructions Here: https://github.com/adobe/helix-cli?tab=readme-ov-file#setting-up-a-self-signed-cert-for-using-https
# AEM_TLS_KEY="server.key"
# AEM_TLS_CERT="server.crt"
AEM_TLS_KEY="server.key"
AEM_TLS_CERT="server.crt"

#--- OPTIONAL LOCAL EDS CONFIGURATION ---
# Stop EDS from automatically opening the browser when starting locally
# AEM_NO_OPEN=true

# Stop Live Reload from automatically refreshing the browser when starting locally
# AEM_LIVERELOAD=false

# AEM Cloud Author Instance Configuration
# Copy this file to .env and fill in your actual values
# .env is gitignored and should never be committed

# ===================================================================
# ADMIN API CONFIGURATION (RECOMMENDED - for setup-multisite-config.js)
# ===================================================================

# Get your Admin Auth Token:
# 1. Open: https://admin.hlx.page/login
# 2. Click "login_adobe" 
# 3. Open DevTools → Application → Cookies → https://admin.hlx.page
# 4. Copy the value of "auth_token" cookie
# ADMIN_AUTH_TOKEN=

# Optional: Your admin email address
# ADMIN_EMAIL=some.body@blueacorninc.com

# Optional: Technical account from AEM
# Get from: AEM → Tools → Cloud Services → Edge Delivery Services Config
# TECHNICAL_ACCOUNT_EMAIL=

# ===================================================================
# AEM CLOUD CONFIGURATION
# ===================================================================

# AEM Cloud Author Instance
# Example: https://author-p13952-e1145522.adobeaemcloud.com
# AEM_AUTHOR_URL=https://author-pXXXXX-eXXXXXX.adobeaemcloud.com

# AEM Credentials (for local AEM instances only)
# AEM_AUTHOR_USER=your-username
# AEM_AUTHOR_PASS=your-password

# AEM Cloud Local Development Token (24 hour validity)
# Get from: AEM Cloud Developer Console > Integrations > Local Token > Get Local Development Token
# NOTE: This token is READ-ONLY. Use for testing API connectivity, not for page creation.
# AEM_DEV_TOKEN=eyJhbG...your-token-here

# AEM Cloud Service Account (for write operations: page creation, updates, etc.)
# Generate via Adobe Developer Console: https://developer.adobe.com/console
# 1. Create/select project
# 2. Add API: Experience Manager - AEM Sites API
# 3. Create Service Account (JWT) credentials
# 4. Download credentials JSON
# 5. Set path to credentials file below (absolute or relative to tools/aem-page-creator/)
# AEM_SERVICE_ACCOUNT_JSON=./service-credentials.json

# Adobe I/O CLI Configuration (for aio commands)
# These are set via `aio auth:login` and `aio cloudmanager:org:select`
# AIO_runtime_auth=
# AIO_runtime_namespace=

# Context-7 API Configuration (for context-7 skill)
# Generate your API key at https://context7.com/dashboard
# CONTEXT7_API_KEY=your-api-key-here
